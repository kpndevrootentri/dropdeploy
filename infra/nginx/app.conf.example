# DropDeploy main API vhost — copy to /etc/nginx/sites-enabled/dropdeploy.conf
# Replace YOUR_BASE_DOMAIN (e.g. en3.wtf) and YOUR_APP_PORT (default 3001).
#
# Deploy:
#   1. cp infra/nginx/app.conf.example /etc/nginx/sites-enabled/dropdeploy.conf
#   2. sed -i 's/YOUR_BASE_DOMAIN/en3.wtf/g; s/YOUR_APP_PORT/3001/g' /etc/nginx/sites-enabled/dropdeploy.conf
#   3. certbot --nginx -d app.YOUR_BASE_DOMAIN
#   4. nginx -t && nginx -s reload

server {
    listen 80;
    server_name app.YOUR_BASE_DOMAIN;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name app.YOUR_BASE_DOMAIN;

    # Let's Encrypt SSL
    ssl_certificate     /etc/letsencrypt/live/YOUR_BASE_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_BASE_DOMAIN/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers off;

    # ─── Security: block internal endpoints ──────────────────────────────────
    # /api/metrics is an unauthenticated Prometheus scrape endpoint. It must
    # never be reachable from the internet — Prometheus reaches it via
    # host-gateway (Docker internal) only.
    location = /api/metrics {
        deny all;
        return 403;
    }

    # ─── DropDeploy Next.js API ───────────────────────────────────────────────
    location / {
        proxy_pass http://127.0.0.1:YOUR_APP_PORT;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
