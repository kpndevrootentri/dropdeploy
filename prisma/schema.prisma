// DropDeploy - Prisma schema (PRD-aligned)
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CONTRIBUTOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role              UserRole @default(USER)
  mustResetPassword Boolean  @default(false) @map("must_reset_password")

  projects  Project[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Project {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  source      SourceType
  githubUrl   String?    @map("github_url")
  type        ProjectType
  branch      String     @default("main")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deployments          Deployment[]
  environmentVariables EnvironmentVariable[]
  auditLogs            AuditLog[]
  androidBuildConfig   AndroidBuildConfig?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("projects")
}

model Deployment {
  id            String           @id @default(cuid())
  status        DeploymentStatus @default(QUEUED)
  containerPort Int?             @map("container_port")
  subdomain     String?          @unique
  buildStep     String?          @map("build_step")
  buildLog      String?          @map("build_log") @db.Text
  commitHash    String?          @map("commit_hash")
  startedAt     DateTime?        @map("started_at")
  completedAt   DateTime?        @map("completed_at")

  artifactUrl  String? @map("artifact_url")
  artifactType String? @map("artifact_type")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("deployments")
}

enum SourceType {
  GITHUB
}

enum ProjectType {
  STATIC
  NODEJS
  NEXTJS
  DJANGO
  REACT
  FASTAPI
  FLASK
  VUE
  SVELTE
  ANDROID
}

model EnvironmentVariable {
  id             String          @id @default(cuid())
  key            String
  encryptedValue String          @map("encrypted_value") @db.Text
  iv             String
  authTag        String          @map("auth_tag")
  environment    EnvEnvironment  @default(ALL)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, key, environment])
  @@index([projectId])
  @@map("environment_variables")
}

enum EnvEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
  ALL
}

model AuditLog {
  id        String @id @default(cuid())
  action    String // ENV_CREATED, ENV_UPDATED, ENV_DELETED
  targetKey String @map("target_key")

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id])

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([userId])
  @@map("audit_logs")
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  DEPLOYED
  FAILED
  CANCELLED
}

model AndroidBuildConfig {
  id        String  @id @default(cuid())
  projectId String  @unique @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  buildType     String @default("debug") @map("build_type")
  gradleTask    String @default("assembleDebug") @map("gradle_task")
  apkOutputPath String @default("app/build/outputs/apk/debug/app-debug.apk") @map("apk_output_path")

  keystoreBase64     String? @map("keystore_base64") @db.Text
  keystoreIv         String? @map("keystore_iv")
  keystoreAuthTag    String? @map("keystore_auth_tag")
  keystoreAlias      String? @map("keystore_alias")
  keystorePassword   String? @map("keystore_password") @db.Text
  keystorePasswordIv         String? @map("keystore_password_iv")
  keystorePasswordAuthTag    String? @map("keystore_password_auth_tag")
  keyPassword        String? @map("key_password") @db.Text
  keyPasswordIv      String? @map("key_password_iv")
  keyPasswordAuthTag String? @map("key_password_auth_tag")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("android_build_configs")
}
