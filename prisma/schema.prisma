// DropDeploy - Prisma schema (PRD-aligned)
// https://www.prisma.io/docs/concepts/components/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CONTRIBUTOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role              UserRole @default(USER)
  mustResetPassword Boolean  @default(false) @map("must_reset_password")

  projects      Project[]
  auditLogs     AuditLog[]
  gitProviders  GitProvider[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Project {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  source      SourceType
  githubUrl   String?    @map("github_url")
  type        ProjectType
  branch      String     @default("main")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deployments          Deployment[]
  environmentVariables EnvironmentVariable[]
  auditLogs            AuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("projects")
}

model Deployment {
  id            String           @id @default(cuid())
  status        DeploymentStatus @default(QUEUED)
  containerPort Int?             @map("container_port")
  subdomain     String?          @unique
  buildStep     String?          @map("build_step")
  buildLog      String?          @map("build_log") @db.Text
  commitHash    String?          @map("commit_hash")
  startedAt     DateTime?        @map("started_at")
  completedAt   DateTime?        @map("completed_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("deployments")
}

enum SourceType {
  GITHUB
  GITLAB
}

model GitProvider {
  id             String     @id @default(cuid())
  provider       SourceType
  providerUserId String     @map("provider_user_id")
  username       String
  avatarUrl      String?    @map("avatar_url")

  encryptedToken String     @db.Text @map("encrypted_token")
  iv             String
  authTag        String     @map("auth_tag")

  // GitLab only — refresh token and expiry (GitHub tokens don't expire)
  encryptedRefreshToken String?   @db.Text @map("encrypted_refresh_token")
  refreshIv             String?   @map("refresh_iv")
  refreshAuthTag        String?   @map("refresh_auth_tag")
  tokenExpiresAt        DateTime? @map("token_expires_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // One account per provider per user (intentional v1 constraint)
  @@unique([userId, provider])
  @@index([userId])
  @@map("git_providers")
}

enum ProjectType {
  STATIC
  NODEJS
  NEXTJS
  DJANGO
  REACT
  FASTAPI
  FLASK
  VUE
  SVELTE
}

model EnvironmentVariable {
  id             String          @id @default(cuid())
  key            String
  encryptedValue String          @map("encrypted_value") @db.Text
  iv             String
  authTag        String          @map("auth_tag")
  environment    EnvEnvironment  @default(ALL)

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, key, environment])
  @@index([projectId])
  @@map("environment_variables")
}

enum EnvEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
  ALL
}

model AuditLog {
  id        String @id @default(cuid())
  action    String // ENV_CREATED, ENV_UPDATED, ENV_DELETED
  targetKey String @map("target_key")

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id])

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([userId])
  @@map("audit_logs")
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  DEPLOYED
  FAILED
  CANCELLED
}
