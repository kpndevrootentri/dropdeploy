# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dropdeploy"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Auth
JWT_SECRET="your-secret-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENV_ENCRYPTION_KEY=""

# Docker
DOCKER_SOCKET="/var/run/docker.sock"

# Storage directories (auto-created if they don't exist)
# PROJECTS_DIR defaults to ~/.dropdeploy/projects
# DOCKER_DATA_DIR defaults to ~/.dropdeploy/docker
PROJECTS_DIR=""
DOCKER_DATA_DIR=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Deployment — both must match your domain
BASE_DOMAIN="yourdomain.com"
NEXT_PUBLIC_BASE_DOMAIN="yourdomain.com"
NGINX_CONFIG_PATH="/etc/nginx/sites-enabled"

# Worker tuning (optional — defaults shown)
# BULLMQ_CONCURRENCY="5"         # max simultaneous builds (1–20)
# BULLMQ_JOB_TIMEOUT_MS="900000" # per-job timeout in ms (default: 15 min)

# Admin / contributor account — used by scripts/seed-contributor.ts
# CONTRIBUTOR_EMAIL="admin@yourdomain.com"
# CONTRIBUTOR_PASSWORD="<strong-password>"

# Security — comma-separated list of extra blocked npm/pip package names
# Merged with the built-in blocklist at deploy time
# BLOCKED_PACKAGES="my-bad-pkg,another-evil-lib"

# Logging level: error | warn | info | http | verbose | debug | silly
# LOG_LEVEL="info"

# Dev (localhost): when NEXT_PUBLIC_APP_URL contains localhost, deployed project URLs
# show as http://localhost:<port>. Set NEXT_PUBLIC_USE_LOCALHOST_DEPLOY_URL=true to
# force localhost URLs without changing NEXT_PUBLIC_APP_URL.
